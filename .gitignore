# NotebookLM automation outputs must never become NotebookLM sources again.
# These paths are ignored by Git; Google Drive Desktop must also exclude them
# if it is configured to sync the whole repository or Desktop.
tools-ai/notebooklm/outputs/
tools-ai/notebooklm/.venv/
tools-ai/notebooklm/chrome_profile/
docs/ai/outputs/*.md
docs/ai/outputs/*.json
!docs/ai/outputs/README.md
!docs/ai/outputs/.gitkeep

# Graphify
graphify-out/cost.json
graphify-out/cache/

# Temp scripts
backend/*.cjs
backend/*.mjs
.graphifyignore
