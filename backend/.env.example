PORT=3001
DATABASE_URL=postgresql://postgres:***@localhost:5432/kavana_v3
ALLOW_MOCK_AUTH=false
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"

# AI Advisor — Industrial assistant
# Provider: 'nvidia' | 'openrouter' | 'openai'
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-***
# LLM_MODEL=meta/llama-3.1-8b-instruct
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# OpenTelemetry — observabilidad y tracing de prompts
# Endpoint del collector (ej: http://localhost:4318 para Grafana Agent / Otel Collector)
# Si no se define, el SDK no se inicializa y no hay telemetría.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
