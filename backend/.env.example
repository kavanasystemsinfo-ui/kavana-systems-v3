PORT=3001
DATABASE_URL=postgresql://kavana:***@localhost:5432/kavana_v3
ALLOW_MOCK_AUTH=false
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"

# AI Advisor — Industrial assistant
# Provider: 'ollama' | 'vllm' | 'nvidia' | 'openrouter' | 'openai'
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-***
OPENROUTER_API_KEY=sk-or-***
# LLM_MODEL=meta/llama-3.1-8b-instruct
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# Job Queue — BullMQ (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenTelemetry — observabilidad y tracing de prompts
# Modo 1: Prometheus local — define METRICS_PORT y levanta docker-compose.observability.yml
METRICS_PORT=9464
# Modo 2: OTLP collector (ej: http://localhost:4318 para Grafana Agent)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Si ninguna está definida, se ejecuta sin telemetría (sin overhead).
